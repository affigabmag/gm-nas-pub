#cloud-config
# ============================================================================
# gm-nas — Ubuntu Server 24.04 LTS autoinstall seed (user-data)
# ----------------------------------------------------------------------------
# Fetched at GRUB via:  autoinstall ds=nocloud-net;s=https://raw.githubusercontent.com/affigabmag/gm-nas-pub/main/
# PUBLIC REPO — no secrets here. SSH public key only. No passwords, no authkeys.
# ============================================================================
autoinstall:
  version: 1

  # --- Locale / input -------------------------------------------------------
  locale: en_US.UTF-8
  keyboard:
    layout: us

  # --- Minimal install ------------------------------------------------------
  # Skips bundled snaps/packages; smaller attack surface (device is remote-reachable).
  source:
    id: ubuntu-server-minimal

  # --- Network --------------------------------------------------------------
  # Build-time only: Ethernet DHCP. End-user home WiFi is handled later by
  # wifi-connect (first-boot flow), NOT here. NetworkManager renderer is set
  # in late-commands (wifi-connect depends on NetworkManager).
  network:
    version: 2
    ethernets:
      eth-any:
        match:
          name: "en*"
        dhcp4: true
        optional: true

  # --- Storage --------------------------------------------------------------
  # p1: ESP 1GB (UEFI boot)   p2: / 40GB ext4   p3: rest -> /srv/storage ext4
  # NOTE: targets the first disk. Confirm device size >~1TB before imaging so
  # the installer doesn't pick a USB stick as the target.
  storage:
    config:
      - {type: disk, id: disk0, ptable: gpt, match: {size: largest}, wipe: superblock-recursive, grub_device: true}

      - {type: partition, id: p1, device: disk0, size: 1G, flag: boot, grub_device: true}
      - {type: format, id: fs-esp, volume: p1, fstype: fat32}
      - {type: mount, id: mnt-esp, device: fs-esp, path: /boot/efi}

      - {type: partition, id: p2, device: disk0, size: 40G}
      - {type: format, id: fs-root, volume: p2, fstype: ext4}
      - {type: mount, id: mnt-root, device: fs-root, path: /}

      - {type: partition, id: p3, device: disk0, size: -1}
      - {type: format, id: fs-storage, volume: p3, fstype: ext4}
      - {type: mount, id: mnt-storage, device: fs-storage, path: /srv/storage}

  # --- Identity / user ------------------------------------------------------
  # Password strategy b1: NO password set here. End user sets the admin password
  # via the welcome-app web UI on first setup. Until then Cockpit login is locked
  # (flag /etc/homenas/password-not-set, created in late-commands).
  identity:
    hostname: my-gmnas
    username: gmnas
    # Locked/disabled password ('!'), no console/Cockpit login until web UI sets one.
    password: "!"

  # --- SSH ------------------------------------------------------------------
  # Key-only auth from first boot. Public key below is safe on a public repo.
  ssh:
    install-server: true
    allow-pw: false
    authorized-keys:
      - "ssh-rsa  gm"

  # --- Packages (apt) -------------------------------------------------------
  # Tailscale + ttyd + wifi-connect are NOT apt packages on 24.04 — installed
  # in late-commands (repo / GitHub-release binaries).
  packages:
    - cockpit
    - samba
    - nfs-kernel-server
    - network-manager
    - avahi-daemon
    - curl
    - ca-certificates

  # Keep the box current on its own (security appliance, unattended).
  package_update: true
  package_upgrade: true

  # --- Post-install ---------------------------------------------------------
  late-commands:
    # -- NetworkManager as the netplan renderer (wifi-connect requires NM) ---
    - |
      cat > /target/etc/netplan/01-network-manager-all.yaml <<'EOF'
      network:
        version: 2
        renderer: NetworkManager
      EOF
    - chmod 600 /target/etc/netplan/01-network-manager-all.yaml
    # Remove the installer's networkd config so NM owns all interfaces
    - rm -f /target/etc/netplan/00-installer-config*.yaml

    # -- homenas state dir + flags ------------------------------------------
    # password-not-set : welcome app removes it once admin password is chosen (b1)
    # provisioned      : ABSENT on purpose -> first boot runs wifi-connect AP flow
    - mkdir -p /target/etc/homenas
    - touch /target/etc/homenas/password-not-set

    # -- storage dir ownership ----------------------------------------------
    - chown root:gmnas /target/srv/storage
    - chmod 2775 /target/srv/storage

    # -- Enable core services -----------------------------------------------
    - curtin in-target --target=/target -- systemctl enable ssh
    - curtin in-target --target=/target -- systemctl enable cockpit.socket
    - curtin in-target --target=/target -- systemctl enable NetworkManager
    - curtin in-target --target=/target -- systemctl enable avahi-daemon

    # -- Tailscale ----------------------------------------------------------
    # Official installer adds the apt repo + installs + enables tailscaled.
    # NO authkey here (authkeys are secrets; public repo). The device is NOT
    # logged in at build time — Tailscale auth happens later via the welcome
    # app / `tailscale up` during setup.
    - curtin in-target --target=/target -- bash -c 'curl -fsSL https://tailscale.com/install.sh | sh'
    - curtin in-target --target=/target -- systemctl enable tailscaled

    # -- ttyd (browser terminal binary) -------------------------------------
    # Latest x86_64 static binary from upstream releases. Installed now; its
    # own systemd service + welcome-app embedding come in a later step.
    - >
      curl -fsSL
      "$(curl -fsSL https://api.github.com/repos/tsl0922/ttyd/releases/latest
      | grep browser_download_url | grep '\.x86_64' | head -1 | cut -d '"' -f4)"
      -o /target/usr/local/bin/ttyd
    - chmod +x /target/usr/local/bin/ttyd

    # -- wifi-connect (first-boot captive portal) ---------------------------
    # Latest x86_64 linux release tarball (binary + bundled ui/).
    - >
      curl -fsSL
      "$(curl -fsSL https://api.github.com/repos/balena-os/wifi-connect/releases/latest
      | grep browser_download_url | grep x86_64 | grep -i linux | head -1 | cut -d '"' -f4)"
      -o /tmp/wifi-connect.tar.gz
    - mkdir -p /target/usr/local/lib/wifi-connect
    - tar -xzf /tmp/wifi-connect.tar.gz -C /target/usr/local/lib/wifi-connect
    - chmod +x /target/usr/local/lib/wifi-connect/wifi-connect

    # -- Custom captive-portal UI (branded, guided, mobile-first) -----------
    # Overwrites wifi-connect's default index.html with our own. Served from
    # --ui-directory (see firstboot-wifi.sh).
    - mkdir -p /target/usr/local/lib/wifi-connect/ui
    - >
      curl -fsSL https://raw.githubusercontent.com/affigabmag/gm-nas-pub/main/ui/index.html
      -o /target/usr/local/lib/wifi-connect/ui/index.html

    # -- First-boot provisioning unit + wrapper -----------------------------
    # Fetched from this same public seed repo. The wrapper launches the
    # HomeNAS-Setup AP until the user selects their home WiFi, then writes
    # /etc/homenas/provisioned so it never runs again.
    - >
      curl -fsSL https://raw.githubusercontent.com/affigabmag/gm-nas-pub/main/files/firstboot-wifi.sh
      -o /target/usr/local/sbin/firstboot-wifi.sh
    - chmod +x /target/usr/local/sbin/firstboot-wifi.sh
    - >
      curl -fsSL https://raw.githubusercontent.com/affigabmag/gm-nas-pub/main/files/homenas-firstboot.service
      -o /target/etc/systemd/system/homenas-firstboot.service
    - curtin in-target --target=/target -- systemctl enable homenas-firstboot.service

    # ========================================================================
    # TODO (later build steps):
    #   - ttyd systemd service + reverse-proxy/iframe into welcome app
    #   - Welcome app + its systemd unit (owns password-set flag + shares)
    #   - Custom wifi-connect --ui-directory HTML/CSS (branding + guided copy)
    #   - Tailscale auth flow wired into the welcome app
    # ========================================================================
